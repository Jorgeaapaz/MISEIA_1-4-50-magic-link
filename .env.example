# MongoDB connection string — use your local or cloud MongoDB instance
MONGODB_URI=mongodb://localhost:27017/magiklink

# Secret key for signing JWTs — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-here

# Public URL of your app — used to construct the magic link sent in emails
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMTP server host — use localhost with MailHog for local development
SMTP_HOST=localhost

# SMTP server port — MailHog listens on 1025 by default
SMTP_PORT=1025
